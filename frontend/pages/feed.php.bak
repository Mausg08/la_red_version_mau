        </div>
        <textarea name="details" placeholder="Detalles adicionales (opcional)" rows="2"></textarea>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-secondary" onclick="closeModal('reportModal')">Cancelar</button>
