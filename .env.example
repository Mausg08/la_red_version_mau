# UniLink — Environment Variables
# Copy to .env and fill in your values

APP_ENV=development

# JWT
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_32_CHAR_STRING_HERE

# Database
DB_HOST=localhost
DB_USER=unilink
DB_PASS=securepassword
DB_ROOT_PASSWORD=rootsecurepassword

# Redis
REDIS_PASSWORD=redissecret

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=unilink@youruni.edu.mx
SMTP_PASS=your_app_password

# Storage (MinIO)
MINIO_USER=unilink
MINIO_PASS=minioadmin123

# WebSocket server
WS_PORT=3001
